#!/usr/bin/env sh
echo "Running pre-push checks..."

# Check Prettier formatting across all files (respects .prettierignore).
# Runs on pre-push (not pre-commit) to avoid slowing down the commit flow.
echo "Checking Prettier formatting..."
if ! npm run format:check --silent 2>&1; then
  echo ""
  echo "❌ ERROR: Prettier formatting issues found!"
  echo "Run 'npm run format' to fix them, then commit/amend and push again."
  exit 1
fi

echo "✅ Pre-push checks passed!"
