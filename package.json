{
  "name": "pflanzkalender",
  "version": "1.5.3",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export --platform web && node scripts/add-pwa-meta-tags.js && node scripts/add-splash-screen.js",
    "deploy": "bash scripts/deploy.sh",
    "validate": "./scripts/validate-release.sh",
    "prepare": "husky install",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "homepage": "https://s540d.github.io/Pflanzkalender",
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.1.1",
    "expo": "^56.0.12",
    "expo-constants": "~56.0.18",
    "expo-linking": "~56.0.14",
    "expo-navigation-bar": "~56.0.3",
    "expo-router": "~56.2.11",
    "expo-status-bar": "~56.0.4",
    "firebase": "^12.15.0",
    "qrcode-generator": "^1.4.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.17",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.5",
    "prettier": "^3.8.4",
    "typescript": "~6.0.3"
  },
  "private": true
